# Required — OpenAI API key (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-...

# Optional — model id (default: gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini

# Optional — custom base URL (Azure OpenAI, proxy, etc.)
# OPENAI_BASE_URL=

# MLflow tracking (default: local SQLite)
MLFLOW_TRACKING_URI=sqlite:///mlflow.db
MLFLOW_EXPERIMENT_NAME=crewai-household-financial-pressure

# Optional — SQLite shared-state path (default: crew_state.db in project root)
# CREW_STATE_DB=
